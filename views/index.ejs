<%- include('partials/header.ejs'); -%>

  <div class="box" id="heading">
    <h1>
      <%= listTitle %>
    </h1>
 </div>
  <div class="box">
    <% for(let item of listItems){%>
      <div class="item">
        <form action="/delete" method="post" class="delete-form">
          <button type="submit" name="deleteItemId" value="<%= item.id %>" class="icon-btn" title="Delete"
            aria-label="Delete <%= item.title %>">
            <img class="icon" src="/assets/icons/trash-solid.svg" alt="">
          </button>
        </form>


        <p id="title<%=item.id%>">
          <%= item.title %>
        </p>

        <form class="edit" action="/edit" method="post">
          <input type="hidden" name="updatedItemId" value="<%= item.id %>">
          <input id="input<%=item.id%>" type="text" name="updatedItemTitle" value="<%= item.title %>" autocomplete="off"
            hidden="true" />




































