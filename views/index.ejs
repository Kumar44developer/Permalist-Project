<%- include('partials/header.ejs'); -%>

  <div class="box" id="heading">
    <h1>
      <%= listTitle %>
    </h1>
 </div>
  <div class="box">
    <% for(let item of listItems){%>
      <div class="item">
        <form action="/delete" method="post" class="delete-form">
          <button type="submit" name="deleteItemId" value="<%= item.id %>" class="icon-btn" title="Delete"
            aria-label="Delete <%= item.title %>">
            <img class="icon" src="/assets/icons/trash-solid.svg" alt="">
          </button>
        </form>


        <p id="title<%=item.id%>">
          <%= item.title %>
        </p>

        <form class="edit" action="/edit" method="post">
          <input type="hidden" name="updatedItemId" value="<%= item.id %>">
          <input id="input<%=item.id%>" type="text" name="updatedItemTitle" value="<%= item.title %>" autocomplete="off"
            hidden="true" />
          <button id="done<%=item.id%>" class="edit" type="submit" hidden title="Save"
            aria-label="Save changes for <%= item.title %>"><img class="icon"
              src="/assets/icons/check-solid.svg" alt=""></button>
        </form>
        <button type="button" id="edit<%=item.id%>" class="edit" title="Edit"
          aria-label="Edit <%= item.title %>" onclick="handler('<%=item.id%>')"><img class="icon"
            src="/assets/icons/pencil-solid.svg" alt=""></button>
      </div>
      <% } %>


        <form class="item" action="/add" method="post">
          <input type="text" name="newItem" placeholder="New Item" autocomplete="off" autofocus="true" />
          <button class="add" type="submit" name="list" value="<%= listTitle %>">+</button>
        </form>
  </div>

  <p class="db-status">
    Storage: <strong><%= storageMode %></strong>
    <% if (typeof tableRowCount === 'number') { %>
      · Rows in <code>items</code> table: <strong><%= tableRowCount %></strong>
      <% if (dbPingMs !== null) { %>
        · DB ping: <strong><%= dbPingMs %> ms</strong>
      <% } %>
    <% } %>
    <br>
  </p>

  <script>
    function handler(id) {
      document.getElementById("title" + id).setAttribute("hidden", true)
      document.getElementById("edit" + id).setAttribute("hidden", true)
      document.getElementById("done" + id).removeAttribute("hidden")
      const input = document.getElementById("input" + id)
      input.removeAttribute("hidden")
      input.focus()
      input.select()
    }



























