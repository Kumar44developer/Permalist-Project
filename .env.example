# Copy to .env and fill in your values. Never commit .env.

# Option A – connection URL (if password has @, encode it as %40)
# DATABASE_URL=postgresql://postgres:your_password@localhost:5432/permalist

# Option B – separate fields (passwords with @ work as-is)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your_password_here
PGDATABASE=permalist

# Optional: server port
# PORT=3000

